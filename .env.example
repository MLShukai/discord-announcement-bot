# 必須: Discord Bot トークン
DISCORD_TOKEN=

# 任意: ログ出力ディレクトリ (既定 ./logs)
LOG_DIR=/tmp/discord-announcement-bot/

# 任意: 設定差分・実行時状態の保存先 (既定 ./config-overrides.toml, ./data/state.json)
# Docker では Dockerfile 既定で /app/data 配下に保存される
# CONFIG_OVERRIDES_PATH=./config-overrides.toml
# STATE_PATH=./data/state.json
